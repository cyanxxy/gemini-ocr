{
  "name": "open-gemini-ocr",
  "private": false,
  "version": "1.0.0",
  "description": "Open-source OCR web app for structured extraction from images, PDFs, and URLs using Google Gemini.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanxxy/open-Gemini-ocr.git"
  },
  "homepage": "https://github.com/cyanxxy/open-Gemini-ocr#readme",
  "bugs": {
    "url": "https://github.com/cyanxxy/open-Gemini-ocr/issues"
  },
  "keywords": [
    "ocr",
    "gemini",
    "ai-evals",
    "structured-extraction",
    "pdf",
    "receipt-ocr",
    "invoice-ocr",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "evals": "tsx evals/run.ts",
    "evals:report": "tsx evals/render-report.ts",
    "evals:validate": "tsx evals/validate.ts"
  },
  "dependencies": {
    "@google/genai": "^1.25.0",
    "katex": "^0.16.21",
    "lucide-react": "^0.563.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-router": "^7.9.1",
    "streamdown": "^2.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.7",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.4.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.18"
  }
