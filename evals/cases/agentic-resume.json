{
  "id": "agentic-resume",
  "mode": "agentic",
  "inputPath": "evals/corpus/resume.pdf",
  "agentConfig": {
    "maxIterations": 4,
    "confidenceThreshold": 0.65
  },
  "expectedAssertions": [
    { "type": "json_field_equals", "path": "documentType", "expected": "resume" },
    { "type": "json_field_equals", "path": "normalizedFields.full_name.value", "expected": "Jordan Lee" },
    { "type": "json_field_equals", "path": "normalizedFields.email.value", "expected": "jordan@example.com" },
    { "type": "json_field_exists", "path": "normalizedFields.skills.value" },
    { "type": "contains", "target": "markdown", "value": "Senior Product Designer" },
    { "type": "pass_rate_weight", "value": 1 }
  ],
  "tags": ["resume", "agentic", "record"]
}
